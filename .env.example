# ============================================
# KYZEN ENVIRONMENT VARIABLES
# ============================================
# Copy this file to:
#   server/.env   (for backend)
#   client/.env   (for frontend)
# ============================================

# === SERVER (.env in /server) ===
PORT=5000
MONGODB_URI=mongodb+srv://YOUR_USERNAME:YOUR_PASSWORD@YOUR_CLUSTER.mongodb.net/kyzen?retryWrites=true&w=majority
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE
ADMIN_PASSWORD=kyzen-admin-2026
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# === CLIENT (.env in /client) ===
VITE_API_URL=http://localhost:5000
VITE_WS_URL=http://localhost:5000
